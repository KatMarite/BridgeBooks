# Protea Email Ingestion Credentials
# ⚠️ DO NOT commit real credentials. Copy this file to .env and fill in.
EMAIL_USER=your_email@example.com
EMAIL_PASS=your_app_password
IMAP_SERVER=imap.example.com

# Filter to only process stock updates from this sender
PROTEA_SENDER_EMAIL=stock@proteaboekwinkel.com
PROTEA_SUBJECT_KEYWORD=stock
